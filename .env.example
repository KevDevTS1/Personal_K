# Copia: cp .env.example .env  y rellena las claves (nunca commitear .env)
# Puerto HTTP
# PORT=8787

# ─── Groq (recomendada) — argumentos largos de cada pick
# https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
# GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# ─── The Odds API (secundaria; consume cuota rápida en plan free)
# https://the-odds-api.com
ODDS_API_KEY=
# false = desactiva llamadas; true = limita a ODDS_API_MAX_SPORTS
ODDS_API_ENABLED=false
ODDS_API_MAX_SPORTS=4

# ─── Clima (OpenWeatherMap; wttr.in es fallback sin key)
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─── football-data.org — tablas, detalle de partido (ligas top)
# https://www.football-data.org/
FOOTBALLDATA_API_KEY=

# ─── TheSportsDB — forma reciente, metadatos (vacío = key pública "3")
# https://www.thesportsdb.com/api.php
THESPORTSDB_KEY=

# ─── API-Football (RapidAPI) — ligas MLS/LATAM, etc. (100 req/día free)
# Misma clave en RapidAPI que para dashboard api-football; si solo tienes
# RAPIDAPI_KEY en otro servicio, puedes usarla con API_FOOTBALL_KEY= o RAPIDAPI_KEY= (ver apifootball.js)
API_FOOTBALL_KEY=
# RAPIDAPI_KEY=

# ─── balldontlie (opcional) — NBA stats; sin key = tier gratuito básico
# BALLDONTLIE_API_KEY=
